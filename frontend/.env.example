# Client-side API URL (inlined at build time by Next.js)
# For local dev: set in .env.local to http://localhost:8000
# For deployments: if not set, client requests proxy through Next.js API routes
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL (read at runtime)
# Used by SSR and the API proxy route to reach the backend
# Local dev: http://localhost:8000 | Docker: http://backend:8000
# Railway: set to backend's internal URL (e.g. http://backend.railway.internal:8000)
INTERNAL_API_URL=http://localhost:8000
